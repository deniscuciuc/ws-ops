# ── LLM ──────────────────────────────────────────────────────────────────────
# Provider: ollama | openai | anthropic
WS_OPS_LLM__PROVIDER=ollama
WS_OPS_LLM__OLLAMA__MODEL=llama3.1:8b
WS_OPS_LLM__OLLAMA__BASE_URL=http://localhost:11434

# Remote provider example (OpenAI or any compat endpoint):
# WS_OPS_LLM__PROVIDER=openai
# WS_OPS_LLM__OPENAI__API_KEY=sk-...
# WS_OPS_LLM__OPENAI__MODEL=gpt-4o-mini
# WS_OPS_LLM__OPENAI__BASE_URL=https://api.openai.com/v1

# ── Email — multiple accounts ─────────────────────────────────────────────────
WS_OPS_EMAIL_ACCOUNTS='[
  {
    "name": "work",
    "host": "imap.gmail.com",
    "username": "denis@company.com",
    "password": "app-password",
    "fetch_limit": 50,
    "folders_map": {"work": "INBOX/Work", "receipts": "INBOX/Receipts", "junk": "Spam"}
  }
]'

# ── GitLab — multiple instances ───────────────────────────────────────────────
WS_OPS_GITLAB_INSTANCES='[
  {
    "name": "qgcore",
    "url": "https://gitlab.com",
    "token": "glpat-...",
    "groups": ["quality-game-core", "jackshift"]
  }
]'

# ── GitHub — multiple accounts ────────────────────────────────────────────────
WS_OPS_GITHUB_ACCOUNTS='[
  {
    "name": "personal",
    "token": "ghp_...",
    "orgs": []
  }
]'

# ── Telegram — multiple accounts (Telethon MTProto) ───────────────────────────
WS_OPS_TELEGRAM_ACCOUNTS='[
  {
    "name": "personal",
    "api_id": 12345678,
    "api_hash": "abc123...",
    "session_file": null,
    "watch_chats": ["my_team", "project_chat"],
    "fetch_dms": false,
    "unread_only": true,
    "message_limit": 100
  }
]'

# ── Telegram Bot — outbound digest delivery ───────────────────────────────────
WS_OPS_TELEGRAM_BOT__TOKEN=123456:ABC-...
WS_OPS_TELEGRAM_BOT__CHAT_ID=987654321

# ── Jira — multiple instances ─────────────────────────────────────────────────
WS_OPS_JIRA_INSTANCES='[
  {
    "name": "myorg",
    "server": "https://myorg.atlassian.net",
    "email": "user@example.com",
    "token": "...",
    "projects": ["PROJ"]
  }
]'

# ── Global ────────────────────────────────────────────────────────────────────
WS_OPS_DRY_RUN=false
